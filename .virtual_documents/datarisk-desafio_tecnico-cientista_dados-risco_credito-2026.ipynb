# Exportação
# =========================
df_sub = df_sub.rename(columns={"prob_segmentado":"probabilidade_inadimplencia"})
df_sub[["id_cliente", "probabilidade_inadimplencia"]].to_csv(f"submissao_case.csv", index=False)

